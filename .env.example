# ============================================
# CodeLens Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# LLM - Groq (FREE at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Vector DB - ChromaDB (runs locally, no key needed)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./data/chromadb

# Embeddings - HuggingFace (runs locally, no key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# GitHub (optional - increases rate limits)
GITHUB_TOKEN=your_github_token_here

# AWS S3 (free tier)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=codelens-metadata

# LangFuse (self-hosted LLM tracing - free)
LANGFUSE_PUBLIC_KEY=your_langfuse_key
LANGFUSE_SECRET_KEY=your_langfuse_secret
LANGFUSE_HOST=http://localhost:3002

# App Config
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
MAX_REPO_SIZE_MB=500
MAX_FILES_PER_REPO=10000
LOG_LEVEL=INFO
